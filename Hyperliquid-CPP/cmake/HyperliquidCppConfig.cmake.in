@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(OpenSSL REQUIRED)
find_dependency(boost_beast REQUIRED)
find_dependency(nlohmann_json REQUIRED)
find_dependency(msgpack-cxx REQUIRED)
find_dependency(cryptopp REQUIRED)
find_dependency(libsecp256k1 REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/HyperliquidCPPTargets.cmake")

check_required_components(HyperliquidCPP)